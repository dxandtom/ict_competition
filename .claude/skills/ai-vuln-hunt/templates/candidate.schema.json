{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VulnHunt LLM 候选项",
  "description": "由 LLM 语义 SAST 审查器输出的疑似漏洞。候选项是一个假设；只有 PoC 阶段才可将 status 设为 confirmed。",
  "type": "object",
  "required": ["candidate_id", "file", "line", "sink_class", "taint_path", "trigger_hypothesis", "poc_oracle", "status"],
  "additionalProperties": false,
  "properties": {
    "candidate_id": {"type": "string", "pattern": "^C[0-9]{3,}$"},
    "source_lead": {"type": "string", "description": "来源的 SAST lead_id，或 'discovery'"},
    "file": {"type": "string"},
    "line": {"type": "integer", "minimum": 0},
    "sink_class": {
      "type": "string",
      "enum": ["oob_rw", "use_after_free", "uninit", "int_overflow", "narrowing_sign",
                "deser", "proto_graph", "injection", "ssrf", "path_traversal",
                "weak_crypto", "availability", "contract", "other"]
    },
    "cwe": {"type": "string"},
    "entry_point": {"type": "string", "description": "可达的公共 API / 解析边界"},
    "taint_path": {
      "type": "array", "minItems": 1,
      "items": {"type": "object", "required": ["file", "line", "note"],
                "properties": {"file": {"type": "string"}, "line": {"type": "integer"},
                               "note": {"type": "string"}}}
    },
    "missing_check": {"type": "string", "description": "缺失的边界检查/校验"},
    "trigger_hypothesis": {
      "type": "object",
      "required": ["description", "concrete_input"],
      "properties": {
        "description": {"type": "string"},
        "concrete_input": {"type": "string", "description": "应当触发该漏洞的字面值输入"}
      }
    },
    "poc_oracle": {
      "type": "string",
      "description": "预测的机器判定结果。必须使用与 triage_crash.sh 作为 evidence_type 输出的相同词汇，以便 PoC 实际观测到的判定结果可以自动与此预测进行核对。",
      "enum": ["asan", "ubsan", "msan", "signal_segv", "signal_fpe", "abort", "check_assert",
                "uncaught_exception", "invariant_violation", "differential_mismatch",
                "metamorphic_violation"]
    },
    "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
    "status": {"type": "string", "enum": ["candidate", "refuted", "confirmed", "unconfirmed"]},
    "notes": {"type": "string"}
  }
}
